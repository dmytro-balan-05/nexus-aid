version: "3.9"

services:
  postgres:
    image: postgres:16
    container_name: charity_postgres
    environment:
      POSTGRES_DB: charity_db
      POSTGRES_USER: charity_user
      POSTGRES_PASSWORD: charity_pass
    ports:
      - "5432:5432"
    volumes:
      - pg_data:/var/lib/postgresql/data

volumes:
  pg_data:
